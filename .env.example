# === API ===
API_KEY=
API_HOST=0.0.0.0
API_PORT=8002

# === OpenAI ===
# Прокси (если пусто — используется https://api.openai.com)
AI_PROXY_URL=
# API-ключ OpenAI (нужен если AI_PROXY_URL пустой)
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o
REWRITE_MODEL=gpt-4.1-mini
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large
STT_MODEL=gpt-4o-mini-transcribe

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/DBNAME

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === Memory ===
MEMORY_MAX_MESSAGES=10

# === Debug ===
# true — в ответ добавляется поле debug (query rewrite, timing и т.д.)
RETURN_DEBUG=false
